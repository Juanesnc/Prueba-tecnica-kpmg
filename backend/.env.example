# Puerto del servidor HTTP
PORT=4000

# Secreto para firmar los JWT
JWT_SECRET=cambia-esto-por-un-secreto-seguro
JWT_EXPIRES_IN=1d

# Base de datos (SQLite por defecto para desarrollo local)
DB_DIALECT=sqlite
DB_STORAGE=./data/dev.sqlite

# Origen permitido para CORS (frontend)
CORS_ORIGIN=http://localhost:5173
